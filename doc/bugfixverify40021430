**Bug 3 — 段平均速度，不是瞬时速度**

```python
def test_segment_speed_is_average_not_instantaneous():
    """构造一段内速度不均匀的记录，验证输出是段均值"""
    # 200m 内：前100m用10s(36km/h)，后100m用50s(7.2km/h)
    # 段平均速度 = 200m / 60s = 12 km/h
    timestamps = [0, 10, 60]
    distances  = [0, 100, 200]
    elevations = [100, 100, 100]
    heart_rates = [0, 0, 0]

    segs = FeatureExtractor._extract_from_time_series(
        timestamps, distances, elevations, heart_rates, segment_length_m=200
    )
    assert len(segs) == 1
    expected = (200/1000) / (60/3600)   # 12.0 km/h
    assert abs(segs[0].speed_kmh - expected) < 0.5, \
        f"段速度应≈{expected:.1f}，实际={segs[0].speed_kmh:.1f}"
```

**Bug 5 — rolling_grade_500m 不等于 avg_grade**

```python
def test_rolling_grade_differs_from_avg_grade():
    """坡度有变化时，滚动坡度不应等于当前段坡度"""
    predictor = MLRacePredictor()
    # 前半程上坡 20%，后半程平路 0%
    points = (
        [{'lat': 30+i*0.002, 'lon': 120.0, 'ele': 100+i*4} for i in range(5)] +
        [{'lat': 30+5*0.002+i*0.002, 'lon': 120.0, 'ele': 120} for i in range(5)]
    )
    segments = predictor._create_segments(points, segment_length_km=0.1)
    # 后半程的段：avg_grade≈0，但 rolling_grade_500m 应反映之前的上坡
    last_seg = segments[-1]
    assert last_seg.rolling_grade_500m != last_seg.grade_pct, \
        "rolling_grade_500m 不应与 avg_grade 相同"
```

