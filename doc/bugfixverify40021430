```python
def test_analyze_and_train_exists():
    import tempfile, os
    predictor = MLRacePredictor(records_dir=tempfile.mkdtemp())
    assert hasattr(predictor, 'analyze_and_train'), \
        "MLRacePredictor 缺少 analyze_and_train 方法"
