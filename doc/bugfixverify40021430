def test_gps_drift_does_not_explode_grade():
    """0.1m 的 GPS 漂移不应产生 > 50% 的坡度"""
    elevations = [100.0, 100.3, 100.0, 100.2]   # 轻微噪声
    distances  = [0,     0.1,   0.2,   0.3]      # 仅 0.1m 步长（漂移）
    grades = ElevationFilter.calculate_grade(
        np.array(elevations), np.array(distances), FilterConfig.FIT
    )
    assert np.all(np.abs(grades) <= FilterConfig.FIT['max_grade_pct']), \
        f"GPS漂移产生了异常坡度: {grades}"
